-- ⚙️ 4. CHỨC NĂNG CHỈNH GIAO DIỆN (NÂNG CẤP)

local function ChangeUIStructure(radius, strokeThickness)
    for _, v in pairs(CoreGui:GetDescendants()) do
        if v:IsA("UICorner") then v.CornerRadius = UDim.new(0, radius) end
        if v:IsA("UIStroke") and v.Parent.Name ~= "BellHub_Button" then v.Thickness = strokeThickness end
    end
end

-- PHÔNG CHỮ
Tabs.Settings:AddSection("Phông chữ (Fonts)")
local Fonts = {
    ["Gotham (Chuẩn)"] = Enum.Font.GothamBold,
    ["Pixel (Arcade)"] = Enum.Font.Arcade,
    ["Vui nhộn (Fredoka)"] = Enum.Font.FredokaOne
}
Tabs.Settings:AddDropdown("FontPicker", {
    Title = "Chọn Phông chữ",
    Values = {"Gotham (Chuẩn)", "Pixel (Arcade)", "Vui nhộn (Fredoka)"},
    Default = "Gotham (Chuẩn)",
    Callback = function(Value)
        local selectedFont = Fonts[Value]
        for _, v in pairs(CoreGui:GetDescendants()) do
            if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then v.Font = selectedFont end
        end
    end
})

-- MÀU SẮC THEME (Yêu cầu của bạn: Thay Light bằng Rainbow)
Tabs.Settings:AddSection("Màu sắc Giao diện")
local Themes = {
    ["Tối (Mặc định)"] = "Dark",
    ["Xanh Neon (Aqua)"] = "Aqua",
    ["Hồng Nam Tính (Rose)"] = "Rose",
    ["Tím Huyền Ảo (Amethyst)"] = "Amethyst",
    ["CẦU VỒNG (Rainbow)"] = "Rainbow"
}

Tabs.Settings:AddDropdown("ThemePicker", {
    Title = "Chọn Màu Chủ Đề",
    Values = {"Tối (Mặc định)", "Xanh Neon (Aqua)", "Hồng Nam Tính (Rose)", "Tím Huyền Ảo (Amethyst)", "CẦU VỒNG (Rainbow)"},
    Default = "Tối (Mặc định)",
    Callback = function(Value)
        if Value == "CẦU VỒNG (Rainbow)" then
            rainbowThemeEnabled = true
            -- Fluent không hỗ trợ loop theme quá nhanh, nên mình chọn Aqua làm nền Rainbow
            Fluent:SetTheme("Aqua") 
            Fluent:Notify({Title = "Bell Hub", Content = "Đã kích hoạt chế độ Rainbow!", Duration = 2})
        else
            rainbowThemeEnabled = false
            Fluent:SetTheme(Themes[Value])
        end
    end
})

-- PHONG CÁCH MENU
Tabs.Settings:AddSection("Phong cách Menu")
Tabs.Settings:AddDropdown("MenuStyle", {
    Title = "Chọn Style Giao diện",
    Values = {"Cổ điển (Default)", "Cyberpunk (Neon)", "Tối giản (Minimalist)"},
    Default = "Cổ điển (Default)",
    Callback = function(Value)
        if Value == "Cổ điển (Default)" then ChangeUIStructure(8, 1)
        elseif Value == "Cyberpunk (Neon)" then ChangeUIStructure(0, 3)
        elseif Value == "Tối giản (Minimalist)" then ChangeUIStructure(20, 0) end
    end
})

Tabs.Settings:AddToggle("RGBBtn", { Title = "Bật Viền RGB Nút Tròn", Default = true, Callback = function(Value) rainbowEnabled = Value end })

