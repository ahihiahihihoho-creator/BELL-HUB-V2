-- Hàm thay đổi cấu trúc UI (Bo góc, viền)
local function ChangeUIStructure(radius, strokeThickness)
    for _, v in pairs(CoreGui:GetDescendants()) do
        if v:IsA("UICorner") then v.CornerRadius = UDim.new(0, radius) end
        if v:IsA("UIStroke") and v.Parent.Name ~= "BellHub_Button" then v.Thickness = strokeThickness end
    end
end

-- PHÔNG CHỮ
Tabs.Settings:AddSection("Phông chữ (Fonts)")
local Fonts = {
    ["Gotham (Chuẩn)"] = Enum.Font.GothamBold,
    ["Pixel (Arcade)"] = Enum.Font.Arcade,
    ["Vui nhộn (Fredoka)"] = Enum.Font.FredokaOne,
    ["Hiện đại (Roboto)"] = Enum.Font.RobotoMono,
    ["Cổ điển (Cartoon)"] = Enum.Font.Cartoon
}
Tabs.Settings:AddDropdown("FontPicker", {
    Title = "Chọn Phông chữ",
    Values = {"Gotham (Chuẩn)", "Pixel (Arcade)", "Vui nhộn (Fredoka)", "Hiện đại (Roboto)", "Cổ điển (Cartoon)"},
    Default = "Gotham (Chuẩn)",
    Callback = function(Value)
        local selectedFont = Fonts[Value]
        local function Apply()
            for _, v in pairs(CoreGui:GetDescendants()) do
                if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then v.Font = selectedFont end
            end
        end
        Apply()
        CoreGui.DescendantAdded:Connect(function(v)
            if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then v.Font = selectedFont end
        end)
    end
})

-- PHONG CÁCH MENU (THAY ĐỔI CẤU TRÚC)
Tabs.Settings:AddSection("Phong cách Menu")
Tabs.Settings:AddDropdown("MenuStyle", {
    Title = "Chọn Style Giao diện",
    Description = "Thay đổi hoàn toàn cấu trúc Menu",
    Values = {"Cổ điển (Default)", "Cyberpunk (Neon)", "Tối giản (Minimalist)"},
    Default = "Cổ điển (Default)",
    Callback = function(Value)
        if Value == "Cổ điển (Default)" then
            Fluent:SetTheme("Dark")
            ChangeUIStructure(8, 1) -- Bo góc vừa, viền mỏng
        elseif Value == "Cyberpunk (Neon)" then
            Fluent:SetTheme("Aqua")
            ChangeUIStructure(0, 3) -- Vuông vức, viền dày Neon
            -- Ép font Pixel cho Cyberpunk
            for _, v in pairs(CoreGui:GetDescendants()) do
                if v:IsA("TextLabel") then v.Font = Enum.Font.Arcade end
            end
        elseif Value == "Tối giản (Minimalist)" then
            Fluent:SetTheme("Light")
            ChangeUIStructure(20, 0) -- Bo tròn cực mạnh, không viền
        end
    end
})

