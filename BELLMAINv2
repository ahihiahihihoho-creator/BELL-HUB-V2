local fontMapping = {
    -- --- 3 LOẠI PIXEL ĐẶC BIỆT ---
    ["Pixel Arcade (Nhỏ)"] = Enum.Font.Arcade,
    ["Pixel Square (Vuông)"] = Enum.Font.RobotoMono,
    ["Pixel Retro (Cổ điển)"] = Enum.Font.Code,
    
    -- --- 10+ LOẠI PHÔNG CHỮ KHÁC ---
    ["Gotham Bold"] = Enum.Font.GothamBold,
    ["Gotham Black"] = Enum.Font.GothamBlack,
    ["Ubuntu (Hiện đại)"] = Enum.Font.Ubuntu,
    ["Special Elite (Máy đánh chữ)"] = Enum.Font.SpecialElite,
    ["Oswald (Thanh mảnh)"] = Enum.Font.Oswald,
    ["Fredoka One (Tròn)"] = Enum.Font.FredokaOne,
    ["Bangers (Comic)"] = Enum.Font.Bangers,
    ["Luckiest Guy (Vui nhộn)"] = Enum.Font.LuckiestGuy,
    ["Creepster (Kinh dị)"] = Enum.Font.Creepster,
    ["Sci-Fi (Tương lai)"] = Enum.Font.SciFi,
    ["Fantasy (Kiếm hiệp)"] = Enum.Font.Fantasy
}

local fontNames = {}
for name, _ in pairs(fontMapping) do table.insert(fontNames, name) end
table.sort(fontNames) -- Sắp xếp tên theo thứ tự chữ cái cho dễ tìm

Tabs.Settings:AddDropdown("FontPicker", {
    Title = "Chọn Phông chữ Hệ thống",
    Description = "Bao gồm 3 loại Pixel và 10+ phông chữ đẹp",
    Values = fontNames,
    Default = "Gotham Bold",
    Callback = function(Value)
        local selectedFont = fontMapping[Value]
        
        local function ApplyFont(parent)
            for _, v in pairs(parent:GetDescendants()) do
                if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
                    v.Font = selectedFont
                end
            end
        end

        ApplyFont(game:GetService("CoreGui"))
        ApplyFont(player.PlayerGui)
        
        Fluent:Notify({
            Title = "Bell Hub Font",
            Content = "Đã áp dụng phông chữ: " .. Value,
            Duration = 2
        })
    end
})

