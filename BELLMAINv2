-- 🎛 2. MAIN UI BUTTON (RGB Border)
if player.PlayerGui:FindFirstChild("BellHub_Button") then
    player.PlayerGui.BellHub_Button:Destroy()
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "BellHub_Button"
ScreenGui.Parent = player:WaitForChild("PlayerGui")
ScreenGui.ResetOnSpawn = false

local Button = Instance.new("ImageButton")
Button.Parent = ScreenGui
Button.Size = UDim2.fromOffset(55,55)
Button.Position = UDim2.new(0.1,0,0.2,0)
Button.BackgroundColor3 = Color3.fromRGB(20,20,20)
Button.Image = "rbxassetid://133832126046587"
Button.AutoButtonColor = false

local Corner = Instance.new("UICorner")
Corner.CornerRadius = UDim.new(1,0)
Corner.Parent = Button

local Stroke = Instance.new("UIStroke")
Stroke.Parent = Button
Stroke.Thickness = 3

local hue = 0
local rainbowSpeed = 0.5
local rainbowEnabled = true
local rainbowThemeEnabled = false -- Biến cho màu Rainbow của Menu

RunService.RenderStepped:Connect(function(dt)
    -- Rainbow cho Nút bấm
    if rainbowEnabled then
        hue += dt * rainbowSpeed
        if hue > 1 then hue = 0 end
        Stroke.Color = Color3.fromHSV(hue,1,1)
    end
    
    -- Rainbow cho Menu Fluent (Nếu bật)
    if rainbowThemeEnabled then
        local themeHue = (tick() * 0.2) % 1
        -- Fluent không hỗ trợ đổi màu real-time cho toàn bộ UI qua hàm, 
        -- nhưng ta sẽ ép theme liên tục để tạo hiệu ứng.
        -- Lưu ý: Dùng Aqua hoặc Rose làm nền cho Rainbow.
    end
end)

local dragging, dragStart, startPos
Button.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Button.Position
    end
end)
Button.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Button.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

